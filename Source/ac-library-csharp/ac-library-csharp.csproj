<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0</TargetFrameworks>
    <RootNamespace>AtCoder</RootNamespace>
    <OutputType>Library</OutputType>

    <DotnetVersion>$([System.Version]::Parse($([MSBuild]::GetTargetFrameworkVersion('$(TargetFramework)'))).Major)</DotnetVersion>
    <LangVersion Condition="'$(DotnetVersion)' != ''">$([MSBuild]::Add($(DotnetVersion), 4))</LangVersion>

    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>

    <PackageTags>ac-library-csharp;AtCoder</PackageTags>
    <PackageId>ac-library-csharp</PackageId>
    <Description>C# port of ac-library</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <GeneratePackageOnBuild Condition="'$(Configuration)' == 'Release'">true</GeneratePackageOnBuild>

    <NoWarn>$(NoWarn);CS1574;CA1034;CS1591;CS1734;IDE0039;IDE0251</NoWarn>

    <PackageLicenseExpression></PackageLicenseExpression>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>

    <IsAotCompatible>true</IsAotCompatible>

    <DefineConstants>$(DefineConstants);ATCODER_CONTRACT</DefineConstants>
    <SourceExpander_PackJson_Enabled Condition="'$(Configuration)' != 'Release'">false</SourceExpander_PackJson_Enabled>
    <SourceExpander_Embedder_ExpandInLibrary Condition="'$(Configuration)' != 'Release'">true</SourceExpander_Embedder_ExpandInLibrary>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="ac-library-csharp.Test, " />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SourceExpander.Embedder.PackJson" Version="$(SourceExpanderVersion)" >
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="LICENSE" Pack="True" PackagePath="" />
    <None Include="Math\MathLib.Convolution.Primitives.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>MathLib.Convolution.Primitives.tt</DependentUpon>
    </None>
    <None Update="Math\MathLib.Convolution.Primitives.tt">
      <Generator>TextTemplatingFileGenerator</Generator>
      <LastGenOutput>MathLib.Convolution.Primitives.cs</LastGenOutput>
    </None>
    <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
    <Compile Update="Math\MathLib.Convolution.Primitives.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>MathLib.Convolution.Primitives.tt</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="Microsoft.SourceLink.GitHub" Version="10.0.203">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
